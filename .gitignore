*.jsonl
data/

# Hermes secrets and profile state — never commit these
config.yaml
.env
auth.json
*.session
.hub/

# Developer reference material — context for programming/setup, not shipped
Sources/

# Python
__pycache__/
*.pyc

.DS_Store
